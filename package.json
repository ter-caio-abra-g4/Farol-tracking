{
  "name": "farol-tracking",
  "private": true,
  "version": "1.1.0",
  "description": "Farol Tracking - Dashboard de Integridade",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5175 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "cors": "^2.8.6",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "googleapis": "^171.4.0",
    "lucide-react": "^1.7.0",
    "node-fetch": "^2.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.4",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.g4.farol",
    "productName": "Farol",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "python/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/assets/icon.ico"
    },
    "mac": {
      "icon": "src/assets/icon.png"
    },
    "linux": {
      "icon": "src/assets/icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "ter-caio-abra-g4",
      "repo": "Farol-tracking"
    },
    "npmRebuild": false,
    "buildDependenciesFromSource": false
  }
}
